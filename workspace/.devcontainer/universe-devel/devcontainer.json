{
  "name": "autoware:universe-devel",
  "build": {
    "context": "../..",
    "dockerfile": "../Dockerfile",
    "args": {
      "BASE_IMAGE": "ghcr.io/autowarefoundation/autoware:universe-devel",
      "INSTALL_CUDA_TOOLS": "0",
      "DEFAULT_ROS_DISTRO": "humble",
      "SOURCE_SETUP_FILES": "/opt/autoware/setup.bash;/workspace/install/setup.bash"
    },
    "options": ["--network=host"]
  },
  "remoteUser": "autoware",
  "containerUser": "autoware",
  "updateRemoteUserUID": true,
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind",
  "workspaceFolder": "/workspace",
  "postCreateCommand": "bash .devcontainer/install-deps.sh && bash .devcontainer/update-cspell.sh && sudo sysctl -w kernel.yama.ptrace_scope=0",
  "privileged": true,
  "init": true,
  "containerEnv": {
    "DISPLAY": "${localEnv:DISPLAY}",
    "XAUTHORITY": "${localEnv:XAUTHORITY}",
    "XDG_RUNTIME_DIR": "/tmp/xdg"
  },
  "mounts": [
    "source=/tmp/.X11-unix,target=/tmp/.X11-unix,type=bind",
    "source=/etc/localtime,target=/etc/localtime,type=bind,readonly",
    "source=/dev/dri,target=/dev/dri,type=bind,readonly",
    "source=${localEnv:HOME}/autoware_data,target=/home/autoware/autoware_data,type=bind",
    "source=${localEnv:HOME}/autoware_map,target=/home/autoware/autoware_map,type=bind",
    "source=${localEnv:HOME}/.ssh,target=/home/autoware/.ssh,type=bind",
    "source=${localEnv:HOME}/.webauto,target=/home/autoware/.webauto,type=bind",
    "source=${localEnv:HOME}/.config/Lichtblick,target=/home/autoware/.config/Lichtblick,type=bind",
    "source=${localEnv:HOME}/.ccache,target=/ccache,type=bind"
  ],
  "runArgs": [
    "--rm",
    "--name=${localWorkspaceFolderBasename}",
    "--net=host",
    "--pid=host",
    "--ipc=host",
    "--ulimit=memlock=-1",
    "--ulimit=stack=67108864"
  ],
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.profiles.linux": {
          "bash": {
            "path": "/bin/bash"
          }
        }
      },
      "extensions": [
        "cschlosser.doxdocgen",
        "eamodio.gitlens",
        "foxundermoon.shell-format",
        "github.vscode-pull-request-github",
        "llvm-vs-code-extensions.vscode-clangd",
        "ms-azuretools.vscode-docker",
        "ms-python.black-formatter",
        "ms-python.debugpy",
        "ms-python.python",
        "ms-python.vscode-pylance",
        "Ranch-Hand-Robotics.rde-pack",
        "redhat.vscode-xml",
        "redhat.vscode-yaml",
        "streetsidesoftware.code-spell-checker",
        "timonwong.shellcheck",
        "twxs.cmake",
        "yzhang.markdown-all-in-one"
      ]
    }
  }
}
